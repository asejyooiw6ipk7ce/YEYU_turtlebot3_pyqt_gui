<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
 <class>MainWindow</class>
 <widget class="QMainWindow" name="MainWindow">
  <property name="geometry">
   <rect><x>0</x><y>0</y><width>1180</width><height>820</height></rect>
  </property>
  <property name="windowTitle"><string>TurtleBot3 PyQt GUI Controller</string></property>
  <widget class="QWidget" name="centralwidget">
   <layout class="QVBoxLayout" name="verticalLayout_main">

    <!-- ================= 상단 상태/배터리/cmd_vel/토픽 영역 ================= -->
    <item>
     <layout class="QHBoxLayout" name="horizontalLayout_top">

      <!-- 로봇 상태 -->
      <item>
       <widget class="QGroupBox" name="groupBox_status">
        <property name="title"><string>로봇 상태</string></property>
        <layout class="QVBoxLayout" name="verticalLayout_status">
         <item>
          <widget class="QLabel" name="lbl_robot_status">
           <property name="text"><string>연결 대기</string></property>
           <property name="alignment"><set>Qt::AlignCenter</set></property>
           <property name="styleSheet"><string notr="true">font-size: 16pt; font-weight: bold; color: #555555;</string></property>
          </widget>
         </item>
         <item>
          <widget class="QLabel" name="lbl_connection_status">
           <property name="text"><string>ROS2: 연결 안됨</string></property>
           <property name="alignment"><set>Qt::AlignCenter</set></property>
          </widget>
         </item>
        </layout>
       </widget>
      </item>

      <!-- 배터리 -->
      <item>
       <widget class="QGroupBox" name="groupBox_battery">
        <property name="title"><string>배터리 상태</string></property>
        <layout class="QFormLayout" name="formLayout_battery">
         <item row="0" column="0"><widget class="QLabel" name="label_1"><property name="text"><string>전압(V):</string></property></widget></item>
         <item row="0" column="1"><widget class="QLabel" name="lbl_battery_voltage"><property name="text"><string>--</string></property></widget></item>
         <item row="1" column="0"><widget class="QLabel" name="label_2"><property name="text"><string>잔량(%):</string></property></widget></item>
         <item row="1" column="1"><widget class="QLabel" name="lbl_battery_percentage"><property name="text"><string>--</string></property></widget></item>
         <item row="2" column="0"><widget class="QLabel" name="label_3"><property name="text"><string>상태:</string></property></widget></item>
         <item row="2" column="1"><widget class="QLabel" name="lbl_battery_msg"><property name="text"><string>--</string></property></widget></item>
         <item row="3" column="0" colspan="2">
          <widget class="QLabel" name="lbl_battery_warning">
           <property name="text"><string></string></property>
           <property name="styleSheet"><string notr="true">color: red; font-weight: bold;</string></property>
          </widget>
         </item>
        </layout>
       </widget>
      </item>

      <!-- cmd_vel -->
      <item>
       <widget class="QGroupBox" name="groupBox_cmdvel">
        <property name="title"><string>/cmd_vel 모니터링</string></property>
        <layout class="QFormLayout" name="formLayout_cmdvel">
         <item row="0" column="0"><widget class="QLabel" name="label_4"><property name="text"><string>linear.x:</string></property></widget></item>
         <item row="0" column="1"><widget class="QLabel" name="lbl_cmdvel_linear"><property name="text"><string>0.0</string></property></widget></item>
         <item row="1" column="0"><widget class="QLabel" name="label_5"><property name="text"><string>angular.z:</string></property></widget></item>
         <item row="1" column="1"><widget class="QLabel" name="lbl_cmdvel_angular"><property name="text"><string>0.0</string></property></widget></item>
         <item row="2" column="0" colspan="2">
          <widget class="QLabel" name="lbl_motion_state">
           <property name="text"><string>정지</string></property>
           <property name="styleSheet"><string notr="true">font-weight: bold;</string></property>
          </widget>
         </item>
        </layout>
       </widget>
      </item>

      <!-- 주요 토픽 -->
      <item>
       <widget class="QGroupBox" name="groupBox_topics">
        <property name="title"><string>주요 토픽 모니터링</string></property>
        <layout class="QFormLayout" name="formLayout_topics">
         <item row="0" column="0"><widget class="QLabel" name="label_6"><property name="text"><string>위치 x,y:</string></property></widget></item>
         <item row="0" column="1"><widget class="QLabel" name="lbl_odom_xy"><property name="text"><string>0.00, 0.00</string></property></widget></item>
         <item row="1" column="0"><widget class="QLabel" name="label_7"><property name="text"><string>방향 yaw:</string></property></widget></item>
         <item row="1" column="1"><widget class="QLabel" name="lbl_odom_yaw"><property name="text"><string>0.00</string></property></widget></item>
         <item row="2" column="0"><widget class="QLabel" name="label_8"><property name="text"><string>LiDAR 최소거리:</string></property></widget></item>
         <item row="2" column="1"><widget class="QLabel" name="lbl_lidar_min"><property name="text"><string>--</string></property></widget></item>
         <item row="3" column="0"><widget class="QLabel" name="label_9"><property name="text"><string>Nav 상태:</string></property></widget></item>
         <item row="3" column="1"><widget class="QLabel" name="lbl_nav_state"><property name="text"><string>--</string></property></widget></item>
         <item row="4" column="0"><widget class="QLabel" name="label_10"><property name="text"><string>목표 위치:</string></property></widget></item>
         <item row="4" column="1"><widget class="QLabel" name="lbl_goal_pose"><property name="text"><string>--</string></property></widget></item>
        </layout>
       </widget>
      </item>

     </layout>
    </item>

    <!-- ================= 탭 영역 ================= -->
    <item>
     <widget class="QTabWidget" name="tabWidget">

      <!-- 경유점 탭 -->
      <widget class="QWidget" name="tab_waypoint">
       <attribute name="title"><string>경유점</string></attribute>
       <layout class="QHBoxLayout" name="horizontalLayout_wp">
        <item>
         <layout class="QFormLayout" name="formLayout_wp_input">
          <item row="0" column="0"><widget class="QLabel" name="label_wp1"><property name="text"><string>이름:</string></property></widget></item>
          <item row="0" column="1"><widget class="QLineEdit" name="edit_wp_name"><property name="placeholderText"><string>예) P1</string></property></widget></item>
          <item row="1" column="0"><widget class="QLabel" name="label_wp2"><property name="text"><string>x:</string></property></widget></item>
          <item row="1" column="1"><widget class="QDoubleSpinBox" name="spin_wp_x"><property name="minimum"><double>-100.0</double></property><property name="maximum"><double>100.0</double></property><property name="decimals"><number>3</number></property></widget></item>
          <item row="2" column="0"><widget class="QLabel" name="label_wp3"><property name="text"><string>y:</string></property></widget></item>
          <item row="2" column="1"><widget class="QDoubleSpinBox" name="spin_wp_y"><property name="minimum"><double>-100.0</double></property><property name="maximum"><double>100.0</double></property><property name="decimals"><number>3</number></property></widget></item>
          <item row="3" column="0"><widget class="QLabel" name="label_wp4"><property name="text"><string>yaw(deg):</string></property></widget></item>
          <item row="3" column="1"><widget class="QDoubleSpinBox" name="spin_wp_yaw"><property name="minimum"><double>-360.0</double></property><property name="maximum"><double>360.0</double></property><property name="decimals"><number>1</number></property></widget></item>
          <item row="4" column="0" colspan="2"><widget class="QPushButton" name="btn_wp_add"><property name="text"><string>경유점 등록</string></property></widget></item>
         </layout>
        </item>
        <item>
         <layout class="QVBoxLayout" name="verticalLayout_wp_list">
          <item><widget class="QListWidget" name="list_waypoints"/></item>
          <item>
           <layout class="QHBoxLayout" name="horizontalLayout_wp_btns">
            <item><widget class="QPushButton" name="btn_wp_move"><property name="text"><string>선택 이동</string></property></widget></item>
            <item><widget class="QPushButton" name="btn_wp_delete"><property name="text"><string>삭제</string></property></widget></item>
            <item><widget class="QPushButton" name="btn_wp_clear"><property name="text"><string>전체 초기화</string></property></widget></item>
            <item><widget class="QPushButton" name="btn_wp_save"><property name="text"><string>파일로 저장</string></property></widget></item>
            <item><widget class="QPushButton" name="btn_wp_load"><property name="text"><string>파일 불러오기</string></property></widget></item>
           </layout>
          </item>
         </layout>
        </item>
       </layout>
      </widget>

      <!-- Trajectory 탭 -->
      <widget class="QWidget" name="tab_trajectory">
       <attribute name="title"><string>Trajectory</string></attribute>
       <layout class="QVBoxLayout" name="verticalLayout_traj">
        <item>
         <layout class="QHBoxLayout" name="horizontalLayout_traj_select">
          <item><widget class="QLabel" name="label_traj1"><property name="text"><string>Trajectory 선택:</string></property></widget></item>
          <item><widget class="QComboBox" name="combo_trajectory"/></item>
          <item><widget class="QPushButton" name="btn_traj_run"><property name="text"><string>실행</string></property></widget></item>
          <item><widget class="QPushButton" name="btn_traj_stop"><property name="text"><string>정지</string></property></widget></item>
         </layout>
        </item>
        <item><widget class="QTextEdit" name="text_traj_info"><property name="readOnly"><bool>true</bool></property></widget></item>
        <item><widget class="QLabel" name="lbl_traj_current_wp"><property name="text"><string>현재 waypoint: --</string></property></widget></item>
       </layout>
      </widget>

      <!-- gTTS 탭 -->
      <widget class="QWidget" name="tab_tts">
       <attribute name="title"><string>gTTS</string></attribute>
       <layout class="QVBoxLayout" name="verticalLayout_tts">
        <item><widget class="QTextEdit" name="edit_tts_text"><property name="placeholderText"><string>출력할 문장을 입력하세요. 예) 터틀봇이 출발합니다.</string></property></widget></item>
        <item>
         <layout class="QHBoxLayout" name="horizontalLayout_tts_ctrl">
          <item><widget class="QLabel" name="label_tts1"><property name="text"><string>언어:</string></property></widget></item>
          <item><widget class="QComboBox" name="combo_tts_lang"/></item>
          <item><widget class="QPushButton" name="btn_tts_speak"><property name="text"><string>음성 출력</string></property></widget></item>
          <item><widget class="QLabel" name="lbl_tts_status"><property name="text"><string>대기 중</string></property></widget></item>
         </layout>
        </item>
        <item>
         <layout class="QHBoxLayout" name="horizontalLayout_tts_presets">
          <item><widget class="QPushButton" name="btn_tts_preset1"><property name="text"><string>출발합니다</string></property></widget></item>
          <item><widget class="QPushButton" name="btn_tts_preset2"><property name="text"><string>도착했습니다</string></property></widget></item>
          <item><widget class="QPushButton" name="btn_tts_preset3"><property name="text"><string>배터리를 확인해주세요</string></property></widget></item>
          <item><widget class="QPushButton" name="btn_tts_preset4"><property name="text"><string>장애물이 감지되었습니다</string></property></widget></item>
         </layout>
        </item>
       </layout>
      </widget>

      <!-- 실행 제어 탭 -->
      <widget class="QWidget" name="tab_process">
       <attribute name="title"><string>실행 제어</string></attribute>
       <layout class="QVBoxLayout" name="verticalLayout_process">
        <item>
         <layout class="QGridLayout" name="gridLayout_process">
          <item row="0" column="0"><widget class="QLabel" name="label_p1"><property name="text"><string>Bringup</string></property></widget></item>
          <item row="0" column="1"><widget class="QPushButton" name="btn_bringup_start"><property name="text"><string>실행</string></property></widget></item>
          <item row="0" column="2"><widget class="QPushButton" name="btn_bringup_stop"><property name="text"><string>종료</string></property></widget></item>
          <item row="0" column="3"><widget class="QLabel" name="lbl_bringup_status"><property name="text"><string>중지됨</string></property></widget></item>

          <item row="1" column="0"><widget class="QLabel" name="label_p2"><property name="text"><string>Nav2</string></property></widget></item>
          <item row="1" column="1"><widget class="QPushButton" name="btn_nav2_start"><property name="text"><string>실행</string></property></widget></item>
          <item row="1" column="2"><widget class="QPushButton" name="btn_nav2_stop"><property name="text"><string>종료</string></property></widget></item>
          <item row="1" column="3"><widget class="QLabel" name="lbl_nav2_status"><property name="text"><string>중지됨</string></property></widget></item>

          <item row="2" column="0"><widget class="QLabel" name="label_p3"><property name="text"><string>Teleop</string></property></widget></item>
          <item row="2" column="1"><widget class="QPushButton" name="btn_teleop_start"><property name="text"><string>실행</string></property></widget></item>
          <item row="2" column="2"><widget class="QPushButton" name="btn_teleop_stop"><property name="text"><string>종료</string></property></widget></item>
          <item row="2" column="3"><widget class="QLabel" name="lbl_teleop_status"><property name="text"><string>중지됨</string></property></widget></item>
         </layout>
        </item>
        <item>
         <widget class="QPushButton" name="btn_emergency_stop">
          <property name="text"><string>긴급 정지 (EMERGENCY STOP)</string></property>
          <property name="styleSheet"><string notr="true">background-color: #d9534f; color: white; font-weight: bold; font-size: 14pt; padding: 10px;</string></property>
         </widget>
        </item>
       </layout>
      </widget>

      <!-- 팀별 자유 기능 탭 -->
      <widget class="QWidget" name="tab_extra">
       <attribute name="title"><string>자유 기능</string></attribute>
       <layout class="QVBoxLayout" name="verticalLayout_extra">
        <item>
         <widget class="QGroupBox" name="groupBox_progress">
          <property name="title"><string>미션 진행률</string></property>
          <layout class="QVBoxLayout" name="verticalLayout_progress">
           <item><widget class="QProgressBar" name="progress_mission"><property name="value"><number>0</number></property></widget></item>
          </layout>
         </widget>
        </item>
        <item>
         <widget class="QLabel" name="lbl_extra_placeholder">
          <property name="text"><string>팀별 자유 기능을 이 영역에 추가하세요 (예: 장애물 감지 표시, 노드 목록 표시 등)</string></property>
         </widget>
        </item>
       </layout>
      </widget>

     </widget>
    </item>

    <!-- ================= 로그 영역 ================= -->
    <item>
     <widget class="QGroupBox" name="groupBox_log">
      <property name="title"><string>로그</string></property>
      <property name="maximumSize"><size><width>16777215</width><height>180</height></size></property>
      <layout class="QVBoxLayout" name="verticalLayout_log">
       <item><widget class="QListWidget" name="list_log"/></item>
       <item>
        <layout class="QHBoxLayout" name="horizontalLayout_log_btns">
         <item><widget class="QPushButton" name="btn_log_save"><property name="text"><string>로그 파일로 저장</string></property></widget></item>
         <item><widget class="QPushButton" name="btn_log_clear"><property name="text"><string>로그 지우기</string></property></widget></item>
        </layout>
       </item>
      </layout>
     </widget>
    </item>

   </layout>
  </widget>
  <widget class="QStatusBar" name="statusbar"/>
 </widget>
 <resources/>
 <connections/>
</ui>
